//! SPHINCS+ top-level signature scheme (SLH-DSA).
//!
//! # Two API variants
//!
//! | Variant  | XMSS strategy  | Function prefix       |
//! |----------|----------------|-----------------------|
//! | Baseline | recursive      | `slh_keygen` / `slh_sign` / `slh_verify` |
//! | Optimised| iterative + ‖  | `slh_keygen_fast` / `slh_sign_fast`      |
//!
//! Verification is shared (`slh_verify` / `slh_verify_raw`) because it only
//! walks the stored authentication path.
//!
//! # Key structure (SHA2-256s, N=32)
//!
//! ```text
//! SK = SK.seed(32) ‖ SK.prf(32) ‖ PK.seed(32) ‖ PK.root(32) = 128 bytes
//! PK = PK.seed(32) ‖ PK.root(32)                              =  64 bytes
//! SIG = R(32) ‖ SIG_FORS(10560) ‖ SIG_HT(19200)              = 29792 bytes
//! ```
//!
//! # Algorithm references (FIPS 205)
//! Alg. 18 → `slh_keygen[_fast]`
//! Alg. 19 → `slh_sign[_fast]`
//! Alg. 20 → `slh_verify`

use rand::{RngCore, rngs::OsRng};

use crate::adrs::{Adrs, AdrsType};
use crate::digest;
use crate::fors::{self, ForsSig, ForsTreeSig};
use crate::hash::SphincsHasher;
use crate::ht::{self, HtSig};
use crate::params::{A, D, HP, K, N, WOTS_LEN};
use crate::wots::WotsSig;
use crate::xmss::{self, XmssSig};

// ── Key types ─────────────────────────────────────────────────────────────────

pub struct SphincsSK {
    pub sk_seed: [u8; N],
    pub sk_prf:  [u8; N],
    pub pk_seed: [u8; N],
    pub pk_root: [u8; N],
}

pub struct SphincsPK {
    pub pk_seed: [u8; N],
    pub pk_root: [u8; N],
}

pub struct SphincsSignature {
    pub r:        [u8; N],
    pub fors_sig: ForsSig,
    pub ht_sig:   HtSig,
}

// ── Digest helpers ────────────────────────────────────────────────────────────

fn top_layer_adrs() -> Adrs {
    let mut adrs = Adrs::new(AdrsType::TreeNode);
    adrs.set_layer_address((D - 1) as u32);
    adrs.set_tree_address(0);
    adrs
}

// ── Baseline API (FIPS 205, recursive XMSS) ──────────────────────────────────

/// Generate a key pair using the **baseline** recursive XMSS strategy (Alg. 18).
pub fn slh_keygen<S: SphincsHasher>() -> (SphincsSK, SphincsPK) {
    let mut sk_seed = [0u8; N];
    let mut sk_prf  = [0u8; N];
    let mut pk_seed = [0u8; N];
    OsRng.fill_bytes(&mut sk_seed);
    OsRng.fill_bytes(&mut sk_prf);
    OsRng.fill_bytes(&mut pk_seed);

    let pk_root = xmss::xmss_node::<S>(&sk_seed, 0, HP, &pk_seed, top_layer_adrs());

    let sk = SphincsSK { sk_seed, sk_prf, pk_seed, pk_root };
    let pk = SphincsPK { pk_seed, pk_root };
    (sk, pk)
}

/// Sign with the **baseline** recursive strategy (Alg. 19).
pub fn slh_sign<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> SphincsSignature {
    let r      = S::prf_msg(&sk.sk_prf, &sk.pk_seed, msg);
    let digest = S::h_msg(&r, &sk.pk_seed, &sk.pk_root, msg);
    let (md, idx_tree, idx_leaf) = digest::split_digest(&digest);

    let f_adrs   = digest::fors_adrs(idx_tree, idx_leaf);
    let fors_sig = fors::fors_sign::<S>(&md, &sk.sk_seed, &sk.pk_seed, &f_adrs);
    let fors_pk  = fors::fors_pk_from_sig::<S>(&fors_sig, &md, &sk.pk_seed, &f_adrs);

    let ht_sig = ht::ht_sign::<S>(&fors_pk, &sk.sk_seed, &sk.pk_seed, idx_tree, idx_leaf);
    SphincsSignature { r, fors_sig, ht_sig }
}

// ── Optimised API (iterative bottom-up + optional Rayon) ─────────────────────

/// Generate a key pair using the **optimised** iterative + parallel strategy.
///
/// Replaces the recursive `xmss_node` call with `xmss_node_fast`, which
/// builds the top-level XMSS tree bottom-up and (with `--features parallel`)
/// parallelises the 2^HP leaf evaluations across CPU cores.
///
/// # Performance vs baseline
///
/// | Metric            | Baseline       | Optimised (sequential) | Optimised (parallel, P cores) |
/// |-------------------|----------------|------------------------|-------------------------------|
/// | Leaf evaluations  | 2^HP = 256     | 2^HP = 256             | 2^HP = 256                    |
/// | Internal h_two    | 2^HP − 1 = 255 | 2^HP − 1 = 255         | 2^HP − 1 = 255                |
/// | Leaf parallelism  | none           | none                   | ~P× speedup                   |
/// | Stack depth       | HP = 8 frames  | O(1) (iterative)       | O(1) (iterative)              |
pub fn slh_keygen_fast<S: SphincsHasher>() -> (SphincsSK, SphincsPK) {
    let mut sk_seed = [0u8; N];
    let mut sk_prf  = [0u8; N];
    let mut pk_seed = [0u8; N];
    OsRng.fill_bytes(&mut sk_seed);
    OsRng.fill_bytes(&mut sk_prf);
    OsRng.fill_bytes(&mut pk_seed);

    // ← only this call differs: iterative bottom-up tree
    let pk_root = xmss::xmss_node_fast::<S>(&sk_seed, 0, HP, &pk_seed, top_layer_adrs());

    let sk = SphincsSK { sk_seed, sk_prf, pk_seed, pk_root };
    let pk = SphincsPK { pk_seed, pk_root };
    (sk, pk)
}

/// Sign with the **optimised** iterative + parallel strategy (Alg. 19).
///
/// Each of the D XMSS layers builds its tree bottom-up (and in parallel with
/// the `parallel` feature) instead of recomputing subtrees per auth-path node.
pub fn slh_sign_fast<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> SphincsSignature {
    let r      = S::prf_msg(&sk.sk_prf, &sk.pk_seed, msg);
    let digest = S::h_msg(&r, &sk.pk_seed, &sk.pk_root, msg);
    let (md, idx_tree, idx_leaf) = digest::split_digest(&digest);

    let f_adrs   = digest::fors_adrs(idx_tree, idx_leaf);
    let fors_sig = fors::fors_sign::<S>(&md, &sk.sk_seed, &sk.pk_seed, &f_adrs);
    let fors_pk  = fors::fors_pk_from_sig::<S>(&fors_sig, &md, &sk.pk_seed, &f_adrs);

    // ← only this call differs: ht_sign_fast uses xmss_sign_fast internally
    let ht_sig = ht::ht_sign_fast::<S>(&fors_pk, &sk.sk_seed, &sk.pk_seed, idx_tree, idx_leaf);
    SphincsSignature { r, fors_sig, ht_sig }
}

// ── Shared verification ───────────────────────────────────────────────────────

/// Verify a signature (FIPS 205 Alg. 20). Shared by both strategies.
pub fn slh_verify<S: SphincsHasher>(
    msg: &[u8],
    sig: &SphincsSignature,
    pk: &SphincsPK,
) -> bool {
    let digest = S::h_msg(&sig.r, &pk.pk_seed, &pk.pk_root, msg);
    let (md, idx_tree, idx_leaf) = digest::split_digest(&digest);

    let f_adrs  = digest::fors_adrs(idx_tree, idx_leaf);
    let fors_pk = fors::fors_pk_from_sig::<S>(&sig.fors_sig, &md, &pk.pk_seed, &f_adrs);

    ht::ht_verify::<S>(&fors_pk, &sig.ht_sig, &pk.pk_seed, idx_tree, idx_leaf, &pk.pk_root)
}

// ── Byte-level serialisation ──────────────────────────────────────────────────
//
// SIG_BYTES = N + K*(1+A)*N + D*(WOTS_LEN+HP)*N
//           = 32 + 22*15*32 + 8*75*32
//           = 32 + 10560 + 19200 = 29792  (SHA2-256s)

/// Total byte length of a serialised SPHINCS+ signature.
pub const SIG_BYTES: usize =
    N                          // R
    + K * (1 + A) * N          // SIG_FORS
    + D * (WOTS_LEN + HP) * N; // SIG_HT

/// Serialise a [`SphincsSignature`] into a `SIG_BYTES`-byte `Vec`.
pub fn serialise_sig(sig: &SphincsSignature) -> Vec<u8> {
    let mut out = Vec::with_capacity(SIG_BYTES);
    out.extend_from_slice(&sig.r);
    for tree in &sig.fors_sig.trees {
        out.extend_from_slice(&tree.sk);
        for node in &tree.auth { out.extend_from_slice(node); }
    }
    for xs in &sig.ht_sig.xmss_sigs {
        for cv in &xs.sig_wots { out.extend_from_slice(cv); }
        for node in &xs.auth   { out.extend_from_slice(node); }
    }
    debug_assert_eq!(out.len(), SIG_BYTES);
    out
}

/// Deserialise raw bytes into a [`SphincsSignature`].
/// Returns `None` if the byte slice has wrong length.
pub fn deserialise_sig(bytes: &[u8]) -> Option<SphincsSignature> {
    if bytes.len() != SIG_BYTES { return None; }
    let mut pos = 0;
    let read = |pos: &mut usize| -> [u8; N] {
        let mut out = [0u8; N];
        out.copy_from_slice(&bytes[*pos..*pos + N]);
        *pos += N;
        out
    };

    let r = read(&mut pos);

    let mut fors_trees = Vec::with_capacity(K);
    for _ in 0..K {
        let sk = read(&mut pos);
        let mut auth = [[0u8; N]; A];
        for node in auth.iter_mut() { *node = read(&mut pos); }
        fors_trees.push(ForsTreeSig { sk, auth });
    }

    let mut xmss_sigs = Vec::with_capacity(D);
    for _ in 0..D {
        let mut sig_wots: WotsSig = [[0u8; N]; WOTS_LEN];
        for cv in sig_wots.iter_mut() { *cv = read(&mut pos); }
        let mut auth = [[0u8; N]; HP];
        for node in auth.iter_mut() { *node = read(&mut pos); }
        xmss_sigs.push(XmssSig { sig_wots, auth });
    }

    Some(SphincsSignature {
        r,
        fors_sig: fors::ForsSig { trees: fors_trees },
        ht_sig:   ht::HtSig { xmss_sigs },
    })
}

/// Sign and return raw bytes (for KAT / interoperability).
pub fn slh_sign_raw<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> Vec<u8> {
    serialise_sig(&slh_sign::<S>(msg, sk))
}

/// Sign with the optimised strategy and return raw bytes.
pub fn slh_sign_raw_fast<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> Vec<u8> {
    serialise_sig(&slh_sign_fast::<S>(msg, sk))
}

/// Verify raw bytes (for KAT / interoperability).
pub fn slh_verify_raw<S: SphincsHasher>(msg: &[u8], sig_bytes: &[u8], pk: &SphincsPK) -> bool {
    match deserialise_sig(sig_bytes) {
        Some(sig) => slh_verify::<S>(msg, &sig, pk),
        None      => false,
    }
}

// ── Tests ─────────────────────────────────────────────────────────────────────

// ── Tests ─────────────────────────────────────────────────────────────────────

#[cfg(test)]
mod tests {
    use super::*;
    use crate::hash::RawSha256;
    use crate::params::N;

    // ── Baseline ──────────────────────────────────────────────────────────────

    #[test]
    fn slh_baseline_roundtrip() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg = b"UNSW 26T1 Applied Cryptography baseline";
        let sig = slh_sign::<RawSha256>(msg, &sk);
        assert!(slh_verify::<RawSha256>(msg, &sig, &pk));
    }

    #[test]
    fn slh_baseline_wrong_message_fails() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let sig = slh_sign::<RawSha256>(b"correct", &sk);
        assert!(!slh_verify::<RawSha256>(b"wrong", &sig, &pk));
    }

    // ── Optimised ─────────────────────────────────────────────────────────────

    #[test]
    fn slh_fast_roundtrip() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let msg = b"UNSW 26T1 Applied Cryptography fast";
        let sig = slh_sign_fast::<RawSha256>(msg, &sk);
        assert!(slh_verify::<RawSha256>(msg, &sig, &pk), "fast sign failed");
    }

    #[test]
    fn slh_fast_wrong_message_fails() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let sig = slh_sign_fast::<RawSha256>(b"correct", &sk);
        assert!(!slh_verify::<RawSha256>(b"wrong", &sig, &pk));
    }

    #[test]
    fn slh_keygen_baseline_and_fast_same_root() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let msg = b"root consistency check";
        let sig = slh_sign_fast::<RawSha256>(msg, &sk);
        assert!(slh_verify::<RawSha256>(msg, &sig, &pk));
        assert!(!slh_verify::<RawSha256>(b"other", &sig, &pk));
    }

    #[test]
    fn slh_raw_lengths_equal() {
        let (sk_b, _) = slh_keygen::<RawSha256>();
        let (sk_f, _) = slh_keygen_fast::<RawSha256>();
        let msg = b"length check";
        assert_eq!(
            slh_sign_raw::<RawSha256>(msg, &sk_b).len(),
            slh_sign_raw_fast::<RawSha256>(msg, &sk_f).len(),
        );
        assert_eq!(slh_sign_raw::<RawSha256>(msg, &sk_b).len(), SIG_BYTES);
    }

    #[test]
    fn slh_wrong_key_fails() {
        let (sk1, pk1) = slh_keygen_fast::<RawSha256>();
        let (_, pk2)   = slh_keygen_fast::<RawSha256>();
        let msg = b"cross-key test";
        let sig = slh_sign_fast::<RawSha256>(msg, &sk1);
        assert!( slh_verify::<RawSha256>(msg, &sig, &pk1));
        assert!(!slh_verify::<RawSha256>(msg, &sig, &pk2));
    }

    // ── Serialisation ─────────────────────────────────────────────────────────

    #[test]
    fn sig_serialise_roundtrip() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let msg   = b"serialisation round-trip";
        let sig   = slh_sign_fast::<RawSha256>(msg, &sk);
        let bytes = serialise_sig(&sig);
        let sig2  = deserialise_sig(&bytes).expect("deserialise failed");
        assert!(slh_verify::<RawSha256>(msg, &sig2, &pk));
    }

    #[test]
    fn verify_raw_rejects_truncated() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let mut raw = slh_sign_raw_fast::<RawSha256>(b"trunc", &sk);
        raw.truncate(raw.len() - 1);
        assert!(!slh_verify_raw::<RawSha256>(b"trunc", &raw, &pk));
    }

    #[test]
    fn verify_raw_rejects_bit_flip() {
        let (sk, pk) = slh_keygen_fast::<RawSha256>();
        let mut raw = slh_sign_raw_fast::<RawSha256>(b"flip", &sk);
        raw[N + 16] ^= 0x01;
        assert!(!slh_verify_raw::<RawSha256>(b"flip", &raw, &pk));
    }

    #[test]
    fn sig_bytes_is_29792() {
        assert_eq!(SIG_BYTES, 29792, "signature size must be 29792 bytes");
    }
}