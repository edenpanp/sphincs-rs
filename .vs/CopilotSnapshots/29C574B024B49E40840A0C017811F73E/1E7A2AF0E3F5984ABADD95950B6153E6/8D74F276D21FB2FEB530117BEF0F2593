//! SPHINCS+ top-level signature scheme (SLH-DSA).
//!
//! This module ties together FORS and HT into the three main algorithms.
//!
//! # Key structure
//!
//! ```text
//! SK = (SK.seed ‖ SK.prf ‖ PK.seed ‖ PK.root)   4 × N = 128 bytes
//! PK = (PK.seed ‖ PK.root)                        2 × N =  64 bytes
//! ```
//!
//! # Signature structure
//!
//! ```text
//! SIG = R ‖ SIG_FORS ‖ SIG_HT
//!
//! R        : N bytes
//! SIG_FORS : K trees × (1 + A) × N bytes
//! SIG_HT   : D layers × (WOTS_LEN + HP) × N bytes
//! ```
//!
//! # Algorithm references (FIPS 205)
//!
//! | Alg. | Name          | Function here  |
//! |------|---------------|----------------|
//! | 18   | `slh_keygen`  | [`slh_keygen`] |
//! | 19   | `slh_sign`    | [`slh_sign`]   |
//! | 20   | `slh_verify`  | [`slh_verify`] |

use rand::{RngCore, rngs::OsRng};

use crate::adrs::{Adrs, AdrsType};
use crate::fors::{self, ForsSig};
use crate::hash::SphincsHasher;
use crate::ht::{self, HtSig};
use crate::params::{D, HP, IDX_LEAF_BYTES, IDX_TREE_BYTES, MD_BYTES, N};
use crate::xmss;

// ── Key types ─────────────────────────────────────────────────────────────────

/// SPHINCS+ secret key (128 bytes for N=32).
pub struct SphincsSK {
    /// Master secret randomness for all key derivations.
    pub sk_seed: [u8; N],
    /// PRF key to derive the per-message randomness R.
    pub sk_prf:  [u8; N],
    /// Public seed (domain-separation tweak shared with PK).
    pub pk_seed: [u8; N],
    /// HT root (= `PK.root`, the top-level XMSS tree root).
    pub pk_root: [u8; N],
}

/// SPHINCS+ public key (64 bytes for N=32).
pub struct SphincsPK {
    pub pk_seed: [u8; N],
    pub pk_root: [u8; N],
}

// ── Signature type ────────────────────────────────────────────────────────────

/// A SPHINCS+ signature = R ‖ SIG_FORS ‖ SIG_HT.
pub struct SphincsSignature {
    /// Per-message randomness (N bytes).
    pub r: [u8; N],
    /// FORS signature over the message digest fragment.
    pub fors_sig: ForsSig,
    /// HT signature certifying the FORS public key.
    pub ht_sig: HtSig,
}

// ── Digest splitting ──────────────────────────────────────────────────────────

/// Split the M-byte message digest into (md, idx_tree, idx_leaf).
///
/// ```text
/// md       = digest[0 .. MD_BYTES]
/// idx_tree = digest[MD_BYTES .. MD_BYTES + IDX_TREE_BYTES]  (big-endian u64)
/// idx_leaf = digest[MD_BYTES + IDX_TREE_BYTES .. M]         (big-endian u64)
/// ```
fn split_digest(digest: &[u8; crate::params::M]) -> ([u8; MD_BYTES], u64, u64) {
    let mut md = [0u8; MD_BYTES];
    md.copy_from_slice(&digest[..MD_BYTES]);

    // Right-align into u64 (big-endian, zero-padded on the left)
    let idx_tree = {
        let mut buf = [0u8; 8];
        let len = IDX_TREE_BYTES.min(8);
        buf[8 - len..].copy_from_slice(&digest[MD_BYTES..MD_BYTES + len]);
        u64::from_be_bytes(buf)
    };

    let idx_leaf = {
        let mut buf = [0u8; 8];
        let len = IDX_LEAF_BYTES.min(8);
        let start = MD_BYTES + IDX_TREE_BYTES;
        buf[8 - len..].copy_from_slice(&digest[start..start + len]);
        u64::from_be_bytes(buf)
    };

    (md, idx_tree, idx_leaf)
}

// ── FORS ADRS construction ────────────────────────────────────────────────────

/// Build the FORS address for the given message indices.
///
/// Layer 0, tree = idx_tree, keypair = idx_leaf (the XMSS leaf signing FORS).
fn fors_adrs(idx_tree: u64, idx_leaf: u64) -> Adrs {
    let mut adrs = Adrs::new(AdrsType::ForsTree);
    adrs.set_layer_address(0);
    adrs.set_tree_address(idx_tree);
    adrs.set_keypair_address(idx_leaf as u32);
    adrs
}

// ── Public API ────────────────────────────────────────────────────────────────

/// Generate a SPHINCS+ key pair (FIPS 205 Alg. 18).
///
/// ```text
/// SK.seed, SK.prf, PK.seed ← random bytes
/// PK.root = xmss_node(SK.seed, 0, HP, PK.seed, ADRS at layer D-1, tree 0)
/// SK = (SK.seed, SK.prf, PK.seed, PK.root)
/// PK = (PK.seed, PK.root)
/// ```
pub fn slh_keygen<S: SphincsHasher>() -> (SphincsSK, SphincsPK) {
    let mut sk_seed = [0u8; N];
    let mut sk_prf  = [0u8; N];
    let mut pk_seed = [0u8; N];
    OsRng.fill_bytes(&mut sk_seed);
    OsRng.fill_bytes(&mut sk_prf);
    OsRng.fill_bytes(&mut pk_seed);

    // Compute HT root: top XMSS tree at layer D-1, tree index 0
    let mut adrs = Adrs::new(AdrsType::TreeNode);
    adrs.set_layer_address((D - 1) as u32);
    adrs.set_tree_address(0);
    let pk_root = xmss::xmss_node::<S>(&sk_seed, 0, HP, &pk_seed, adrs);

    let sk = SphincsSK { sk_seed, sk_prf, pk_seed, pk_root };
    let pk = SphincsPK { pk_seed, pk_root };
    (sk, pk)
}

/// Sign a message with SPHINCS+ (FIPS 205 Alg. 19).
///
/// ```text
/// R = PRF_msg(SK.prf, PK.seed, M)
/// digest = H_msg(R, PK.seed, PK.root, M)
/// (md, idx_tree, idx_leaf) = split_digest(digest)
/// SIG_FORS = fors_sign(md, SK.seed, PK.seed, FORS_ADRS)
/// PK_FORS  = fors_PKFromSig(SIG_FORS, md, PK.seed, FORS_ADRS)
/// SIG_HT   = ht_sign(PK_FORS, SK.seed, PK.seed, idx_tree, idx_leaf)
/// return (R, SIG_FORS, SIG_HT)
/// ```
///
/// This implementation uses **deterministic** signing (opt_rand = PK.seed).
/// For randomised signing, replace `pk_seed` in `prf_msg` with fresh randomness.
pub fn slh_sign<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> SphincsSignature {
    // Step 1: derive per-message randomness R
    let r: [u8; N] = S::prf_msg(&sk.sk_prf, &sk.pk_seed, msg);

    // Step 2: hash message to get M-byte digest, then split
    let digest = S::h_msg(&r, &sk.pk_seed, &sk.pk_root, msg);
    let (md, idx_tree, idx_leaf) = split_digest(&digest);

    // Step 3: FORS signature
    let f_adrs   = fors_adrs(idx_tree, idx_leaf);
    let fors_sig = fors::fors_sign::<S>(&md, &sk.sk_seed, &sk.pk_seed, &f_adrs);
    let fors_pk  = fors::fors_pk_from_sig::<S>(&fors_sig, &md, &sk.pk_seed, &f_adrs);

    // Step 4: HT signature certifying the FORS public key
    let ht_sig = ht::ht_sign::<S>(&fors_pk, &sk.sk_seed, &sk.pk_seed, idx_tree, idx_leaf);

    SphincsSignature { r, fors_sig, ht_sig }
}

/// Verify a SPHINCS+ signature (FIPS 205 Alg. 20).
///
/// Returns `true` iff `sig` is a valid signature of `msg` under `pk`.
///
/// ```text
/// digest = H_msg(R, PK.seed, PK.root, M)
/// (md, idx_tree, idx_leaf) = split_digest(digest)
/// PK_FORS = fors_PKFromSig(SIG_FORS, md, PK.seed, FORS_ADRS)
/// return ht_verify(PK_FORS, SIG_HT, PK.seed, idx_tree, idx_leaf, PK.root)
/// ```
pub fn slh_verify<S: SphincsHasher>(
    msg: &[u8],
    sig: &SphincsSignature,
    pk: &SphincsPK,
) -> bool {
    // Step 1: recompute the message digest
    let digest = S::h_msg(&sig.r, &pk.pk_seed, &pk.pk_root, msg);
    let (md, idx_tree, idx_leaf) = split_digest(&digest);

    // Step 2: recover FORS public key from the FORS signature
    let f_adrs  = fors_adrs(idx_tree, idx_leaf);
    let fors_pk = fors::fors_pk_from_sig::<S>(&sig.fors_sig, &md, &pk.pk_seed, &f_adrs);

    // Step 3: verify HT signature against FORS PK and PK.root
    ht::ht_verify::<S>(
        &fors_pk,
        &sig.ht_sig,
        &pk.pk_seed,
        idx_tree,
        idx_leaf,
        &pk.pk_root,
    )
}

// ── Byte-level serialisation ──────────────────────────────────────────────────
//
// SPHINCS+ signatures have a fixed layout:
//
//   R        : N bytes
//   SIG_FORS : K × (N + A×N) bytes  =  K×N×(1+A)  bytes
//   SIG_HT   : D × (WOTS_LEN×N + HP×N) bytes  =  D×N×(WOTS_LEN+HP)  bytes
//
// For SHA2-256s: 32 + 22×(1+14)×32 + 8×(67+8)×32 = 32 + 10560 + 19200 = 29792 bytes.

use crate::fors::ForsTreeSig;
use crate::params::{A, K, WOTS_LEN};
use crate::xmss::XmssSig;
use crate::wots::WotsSig;

/// Total byte length of a serialised SPHINCS+ signature.
pub const SIG_BYTES: usize = N                                  // R
    + K * (1 + A) * N                                           // SIG_FORS
    + D * (WOTS_LEN + HP) * N;                                  // SIG_HT
// = 32 + 10560 + 19200 = 29792 for SHA2-256s

/// Serialise a [`SphincsSignature`] into a fixed-length `SIG_BYTES`-byte array.
///
/// Layout:
/// ```text
/// [0..N]            R
/// [N..N+K(1+A)N]    SIG_FORS: for each tree j: sk_j ‖ auth_j[0..A]
/// [...]             SIG_HT:   for each layer l: sig_wots_l ‖ auth_l[0..HP]
/// ```
pub fn serialise_sig(sig: &SphincsSignature) -> Vec<u8> {
    let mut out = Vec::with_capacity(SIG_BYTES);

    // R
    out.extend_from_slice(&sig.r);

    // SIG_FORS: K trees, each = sk (N bytes) + auth (A × N bytes)
    for tree in &sig.fors_sig.trees {
        out.extend_from_slice(&tree.sk);
        for node in &tree.auth {
            out.extend_from_slice(node);
        }
    }

    // SIG_HT: D layers, each = sig_wots (WOTS_LEN × N bytes) + auth (HP × N bytes)
    for xmss_sig in &sig.ht_sig.xmss_sigs {
        for chain_val in &xmss_sig.sig_wots {
            out.extend_from_slice(chain_val);
        }
        for node in &xmss_sig.auth {
            out.extend_from_slice(node);
        }
    }

    debug_assert_eq!(out.len(), SIG_BYTES, "serialised signature has wrong length");
    out
}

/// Deserialise a raw byte slice into a [`SphincsSignature`].
///
/// Returns `None` if the byte slice has the wrong length.
pub fn deserialise_sig(bytes: &[u8]) -> Option<SphincsSignature> {
    if bytes.len() != SIG_BYTES {
        return None;
    }

    let mut pos = 0;

    // Helper: read exactly L bytes and advance pos
    let read_n = |pos: &mut usize, buf: &[u8]| -> [u8; N] {
        let mut out = [0u8; N];
        out.copy_from_slice(&buf[*pos..*pos + N]);
        *pos += N;
        out
    };

    // R
    let r = read_n(&mut pos, bytes);

    // SIG_FORS
    let mut fors_trees = Vec::with_capacity(K);
    for _ in 0..K {
        let sk = read_n(&mut pos, bytes);
        let mut auth = [[0u8; N]; A];
        for node in auth.iter_mut() {
            *node = read_n(&mut pos, bytes);
        }
        fors_trees.push(ForsTreeSig { sk, auth });
    }

    // SIG_HT
    let mut xmss_sigs = Vec::with_capacity(D);
    for _ in 0..D {
        let mut sig_wots: WotsSig = [[0u8; N]; WOTS_LEN];
        for chain_val in sig_wots.iter_mut() {
            *chain_val = read_n(&mut pos, bytes);
        }
        let mut auth = [[0u8; N]; HP];
        for node in auth.iter_mut() {
            *node = read_n(&mut pos, bytes);
        }
        xmss_sigs.push(XmssSig { sig_wots, auth });
    }

    debug_assert_eq!(pos, SIG_BYTES);

    Some(SphincsSignature {
        r,
        fors_sig: crate::fors::ForsSig { trees: fors_trees },
        ht_sig:   crate::ht::HtSig { xmss_sigs },
    })
}

/// Sign a message and return raw signature bytes (for KAT comparison).
pub fn slh_sign_raw<S: SphincsHasher>(msg: &[u8], sk: &SphincsSK) -> Vec<u8> {
    serialise_sig(&slh_sign::<S>(msg, sk))
}

/// Verify a raw-bytes signature (for KAT and interoperability testing).
pub fn slh_verify_raw<S: SphincsHasher>(
    msg: &[u8],
    sig_bytes: &[u8],
    pk: &SphincsPK,
) -> bool {
    match deserialise_sig(sig_bytes) {
        Some(sig) => slh_verify::<S>(msg, &sig, pk),
        None      => false,
    }
}

// ── Tests ─────────────────────────────────────────────────────────────────────

#[cfg(test)]
mod tests {
    use super::*;
    use crate::hash::RawSha256;

    /// Full SPHINCS+ round-trip: keygen → sign → verify.
    #[test]
    fn slh_roundtrip() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg = b"UNSW 26T1 Applied Cryptography - SPHINCS+";
        let sig = slh_sign::<RawSha256>(msg, &sk);
        assert!(slh_verify::<RawSha256>(msg, &sig, &pk), "slh_verify rejected a valid signature");
    }

    /// A different message must not verify with a signature for another message.
    #[test]
    fn slh_wrong_message_fails() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let sig = slh_sign::<RawSha256>(b"correct", &sk);
        assert!(!slh_verify::<RawSha256>(b"wrong", &sig, &pk), "slh_verify accepted wrong message");
    }

    /// A signature under one key must not verify under a different key.
    #[test]
    fn slh_wrong_key_fails() {
        let (sk1, pk1) = slh_keygen::<RawSha256>();
        let (_, pk2)   = slh_keygen::<RawSha256>();
        let msg = b"cross-key forgery test";
        let sig = slh_sign::<RawSha256>(msg, &sk1);
        assert!(slh_verify::<RawSha256>(msg, &sig, &pk1), "valid sig rejected under pk1");
        assert!(!slh_verify::<RawSha256>(msg, &sig, &pk2), "sig accepted under wrong pk2");
    }

    /// Signing the same message twice produces two signatures
    /// (deterministic variant: they should be identical).
    #[test]
    fn slh_deterministic_signing() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg = b"determinism test";
        let sig1 = slh_sign::<RawSha256>(msg, &sk);
        let sig2 = slh_sign::<RawSha256>(msg, &sk);
        // Both must verify
        assert!(slh_verify::<RawSha256>(msg, &sig1, &pk));
        assert!(slh_verify::<RawSha256>(msg, &sig2, &pk));
        // R values must be equal (deterministic PRF_msg)
        assert_eq!(sig1.r, sig2.r, "deterministic signing produced different R");
    }
}

    // ── Serialisation tests ───────────────────────────────────────────────────

    /// serialise_sig produces exactly SIG_BYTES bytes.
    #[test]
    fn sig_serialise_length() {
        let (sk, _pk) = slh_keygen::<RawSha256>();
        let sig = slh_sign::<RawSha256>(b"length check", &sk);
        let bytes = serialise_sig(&sig);
        assert_eq!(bytes.len(), SIG_BYTES,
            "Expected {} bytes, got {}", SIG_BYTES, bytes.len());
    }

    /// deserialise_sig(serialise_sig(s)) must reproduce a valid signature.
    #[test]
    fn sig_serialise_roundtrip() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg   = b"serialisation round-trip";
        let sig   = slh_sign::<RawSha256>(msg, &sk);
        let bytes = serialise_sig(&sig);
        let sig2  = deserialise_sig(&bytes).expect("deserialise_sig failed");
        assert!(slh_verify::<RawSha256>(msg, &sig2, &pk),
            "Deserialised signature failed verification");
    }

    /// slh_sign_raw / slh_verify_raw end-to-end.
    #[test]
    fn sign_raw_verify_raw_roundtrip() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg     = b"raw bytes API test";
        let raw_sig = slh_sign_raw::<RawSha256>(msg, &sk);
        assert!(slh_verify_raw::<RawSha256>(msg, &raw_sig, &pk));
        assert!(!slh_verify_raw::<RawSha256>(b"wrong", &raw_sig, &pk));
    }

    /// Wrong-length byte slice must return false.
    #[test]
    fn verify_raw_rejects_truncated_sig() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg     = b"truncation test";
        let mut raw = slh_sign_raw::<RawSha256>(msg, &sk);
        raw.truncate(raw.len() - 1);
        assert!(!slh_verify_raw::<RawSha256>(msg, &raw, &pk));
    }

    /// Bit-flip in signature body must fail verification.
    #[test]
    fn verify_raw_rejects_flipped_bit() {
        let (sk, pk) = slh_keygen::<RawSha256>();
        let msg     = b"bit-flip test";
        let mut raw = slh_sign_raw::<RawSha256>(msg, &sk);
        let flip    = super::N + 16; // inside FORS section
        raw[flip]  ^= 0x01;
        assert!(!slh_verify_raw::<RawSha256>(msg, &raw, &pk));
    }